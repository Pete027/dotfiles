shell-integration = zsh
background = 282c34
foreground = ffffff
window-height = 30
window-width = 103

#theme = catppuccin-frappe
background-opacity = 0.9
font-family = FiraCode Nerd Font Mono
#font-size = 13

keybind = shift+alt+space=toggle_quick_terminal
keybind = shift+up=scroll_page_lines:-20
keybind = shift+down=scroll_page_lines:20